# Pick a provider — voyage (default) or openai.
# Only the API key for the selected provider is required.

EMBEDDINGS_PROVIDER=voyage

# --- Voyage AI (default provider) -----------------------------------------
# Free tier: 200M tokens. Sign up: https://dash.voyageai.com/
# Includes voyage-code-3 embeddings + rerank-2.5-lite cross-encoder.
VOYAGE_API_KEY=your-voyage-key
# Optional model overrides:
# VOYAGE_EMBEDDING_MODEL=voyage-code-3
# VOYAGE_RERANK_MODEL=rerank-2.5-lite

# --- OpenAI (alternative provider) ----------------------------------------
# Use if you already have an OpenAI key. No native reranker — search falls
# back to vector-distance ordering. Embedding cost: ~$0.04 (small) /
# ~$0.20 (large) one-time for the full 6,902-summary ingest.
# OPENAI_API_KEY=your-openai-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # or text-embedding-3-large
# OPENAI_BASE_URL=                                # set for Azure / compatible endpoints
